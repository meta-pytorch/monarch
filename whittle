import os
import platform
import shlex
import signal
import subprocess
import sys
import tempfile
import threading
import time

STATE_FILE = ".whittle.json"

AGENT_SKILL = """
# Whittle: test-driven fix workflow

You are using `whittle` to iteratively fix failing tests. The state file
`.whittle.json` tracks which tests are pending, passing, failing, skipped,
