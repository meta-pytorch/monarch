SMOKE_TARGETS = [
    "hyperactor",
    "hyperactor_mesh",
    "fbcode//monarch/python/tests:test_host_mesh",
    "fbcode//monarch/python/tests:test_proc_mesh",
    "fbcode//monarch/python/tests:test_inter_mesh_ping_pong",
    "fbcode//monarch/python/tests:test_actor_error",
    "fbcode//monarch/python/tests:test_python_actors",
    "fbcode//monarch/python/tests:test_actor_logging",
]


def cmd_init(smoke=False):
    save_state(empty_state())
    if smoke:
        cmd_add(SMOKE_TARGETS)
    else:
        comment("initialized .whittle.json")


def cmd_add(targets, include_flaky=False):
    state = load_state()
    new_targets = []
    for t in targets:
        if t not in state["targets"]:
            state["targets"].append(t)
            new_targets.append(t)
    if not new_targets:
        comment("no new targets")
        save_state(state)
        return

    flaky_names = set(state.get("flaky_names", []))
    added_tests = 0
    added_flaky = 0

    for target in new_targets:
        tests = query_tests(target)
        n_tests = 0
        n_flaky = 0
        for t in tests:
            name = t["name"]
            if t["flaky"] and not include_flaky:
                if name not in flaky_names:
                    flaky_names.add(name)
                    added_flaky += 1
                    n_flaky += 1
            else:
                if name not in state["tests"]:
                    state["tests"][name] = "pending"
                    added_tests += 1
                    n_tests += 1
        parts = [str(n_tests)]
        if n_flaky:
            parts.append(f"{n_flaky} flaky")
        print(f"{target}\t{', '.join(parts)}")

    state["flaky_names"] = sorted(flaky_names)
    save_state(state)

    comment(f"added {added_tests} test(s), {added_flaky} flaky excluded")


def cmd_sync(keep_going=False):
    state = load_state()
    if not state["targets"]:
        comment("no targets; run: whittle add <target>")
        sys.exit(1)

    buck_args = get_buck_args()
    flaky_names = set(state.get("flaky_names", []))

    to_run = {
        name: st
        for name, st in state["tests"].items()
        if st not in ("pass", "removed", "skip") and name not in flaky_names
    }

    skipped = sum(1 for s in state["tests"].values() if s == "skip")

    if not to_run:
        if skipped:
            comment(f"no tests to run; {skipped} skipped")
            sys.exit(1)
        comment("all tests passing")
        return

    test_filters = []
    for name in to_run:
        parts = name.split(" - ", 1)
        if len(parts) == 2:
            test_filters.append(parts[1])

    run_targets = []
    for target in state["targets"]:
        if any(test_matches_target(name, target) for name in to_run):
            run_targets.append(target)

    if not run_targets:
        comment("all tests passing")
        return

    pending_count = sum(1 for s in to_run.values() if s == "pending")
    fail_count = sum(1 for s in to_run.values() if s == "fail")
    comment(f"running {len(to_run)} test(s): "
            f"{pending_count} pending, {fail_count} failing")

    with tempfile.NamedTemporaryFile(
        suffix=".json", prefix="whittle-", delete=False
    ) as tmp:
        event_log_path = tmp.name

    try:
        results, stopped, reason = run_tests(
            buck_args, run_targets, test_filters, event_log_path,
            fail_fast=not keep_going,
        )

        for name, status in results.items():
            state["tests"][name] = status

        removed = []
        if not stopped:
            for name in to_run:
                if name not in results and any(
                    test_matches_target(name, t) for t in run_targets
                ):
                    state["tests"][name] = "removed"
                    removed.append(name)

        save_state(state)

        new_pass = sum(1 for s in results.values() if s == "pass")
        new_fail = sum(1 for s in results.values() if s == "fail")

        # Print changed tests, with flake hint after each failure
        for name in sorted(results):
            print(f"{results[name]}\t{name}")
            if results[name] == "fail":
                comment(f"mark flaky: ./whittle flake {name}")
        for name in sorted(removed):
            print(f"removed\t{name}")

        prefix = f"{reason}: " if reason else ""
        comment(f"{prefix}{new_pass} pass, {new_fail} fail")

        total_fail = sum(1 for s in state["tests"].values() if s == "fail")
        total_pending = sum(
            1 for s in state["tests"].values() if s == "pending"
        )
        total_skip = sum(1 for s in state["tests"].values() if s == "skip")
        if total_fail > 0 or total_pending > 0 or total_skip > 0:
            sys.exit(1)
    finally:
        try:
            os.unlink(event_log_path)
        except OSError:
            pass


def cmd_reset(refresh=False):
    state = load_state()
    # Reset all tests to pending
    for name in state["tests"]:
        state["tests"][name] = "pending"
    count = len(state["tests"])

    if refresh:
        # Re-enumerate tests from targets, preserving flaky list
        state["tests"] = {}
        flaky_names = set(state.get("flaky_names", []))
        for target in state["targets"]:
            tests = query_tests(target)
            for t in tests:
                name = t["name"]
                if name in flaky_names:
                    continue
                if t["flaky"] and name not in flaky_names:
                    flaky_names.add(name)
                else:
                    state["tests"][name] = "pending"
        state["flaky_names"] = sorted(flaky_names)
        count = len(state["tests"])

    save_state(state)
    comment(f"reset {count} test(s) to pending")


def cmd_skip(test_name):
    state = load_state()
    test_name = test_name.removeprefix("fbcode//")
    if test_name not in state["tests"]:
        comment(f"unknown test: {test_name}")
        sys.exit(1)
    state["tests"][test_name] = "skip"
    save_state(state)
    print(f"skip\t{test_name}")


def cmd_unskip(test_name=None, all_=False):
    state = load_state()
    if all_:
        count = 0
        for name in state["tests"]:
            if state["tests"][name] == "skip":
                state["tests"][name] = "pending"
                count += 1
        save_state(state)
        comment(f"unskipped {count} test(s)")
        return
    test_name = test_name.removeprefix("fbcode//")
    if test_name not in state["tests"]:
        comment(f"unknown test: {test_name}")
        sys.exit(1)
    if state["tests"][test_name] != "skip":
        comment(f"not skipped: {test_name}")
        return
    state["tests"][test_name] = "pending"
    save_state(state)
    print(f"pending\t{test_name}")


def cmd_pass(test_name):
    state = load_state()
    test_name = test_name.removeprefix("fbcode//")
    if test_name not in state["tests"]:
        comment(f"unknown test: {test_name}")
        sys.exit(1)
    state["tests"][test_name] = "pass"
    save_state(state)
    print(f"pass\t{test_name}")


def cmd_flake(test_name):
    state = load_state()
    test_name = test_name.removeprefix("fbcode//")
    names = state.get("flaky_names", [])
    if test_name in names:
        comment(f"already flaky: {test_name}")
        return
    names.append(test_name)
    names.sort()
    state["flaky_names"] = names
    state["tests"].pop(test_name, None)
    save_state(state)
    print(f"flaky\t{test_name}")


def _buck_cmd_for_test(name):
    """Return a buck2 test command to reproduce a single test."""
    parts = name.split(" - ", 1)
    if len(parts) != 2:
        return None
    target = "fbcode//" + parts[0]
    test_case = parts[1]
    buck_args = " ".join(get_buck_args())
    return f"buck2 test {buck_args} {target} -- {test_case}"


def cmd_agent():
    state = load_state()
    if not state["targets"]:
        comment("no targets; run: whittle init --smoke")
        sys.exit(1)

    failing = [n for n, s in state["tests"].items() if s == "fail"]
    pending = [n for n, s in state["tests"].items() if s == "pending"]
    skipped = [n for n, s in state["tests"].items() if s == "skip"]

    print("Read the whittle skill by running: ./whittle --skill")
    print()
    print("Your job is to make `./whittle sync` exit 0. Follow the workflow")
    print("described in the skill output. The current state is:")
    print()
    print(f"  {len(failing)} failing, {len(pending)} pending, "
          f"{len(skipped)} skipped")
    print()
    if failing:
        print("Failing tests:")
        for name in sorted(failing):
            print(f"  {name}")
        print()
    if skipped:
        print("Skipped tests (must be resolved before sync can succeed):")
        for name in sorted(skipped):
            print(f"  {name}")
        print()
    print("Run `./whittle sync` to start. Fix failures, mark flaky tests,")
    print("and repeat until it exits 0.")


def cmd_status(filter_states=None, verbose=False):
    state = load_state()
    if not state["targets"]:
        comment("no targets; run: whittle add <target>")
        sys.exit(1)

    # Build list of (status, name) pairs
    entries = []
    for name in sorted(state["tests"]):
        entries.append((state["tests"][name], name))
    for name in sorted(state.get("flaky_names", [])):
        entries.append(("flaky", name))

    for status, name in entries:
        if filter_states and status not in filter_states:
            continue
        print(f"{status}\t{name}")
        if verbose:
            buck_cmd = _buck_cmd_for_test(name)
            if buck_cmd:
                comment(buck_cmd)

    comment(summarize_counts(state["tests"], state.get("flaky_names")))

    failing = sum(1 for s in state["tests"].values() if s == "fail")
    pending = sum(1 for s in state["tests"].values() if s == "pending")
    skipped = sum(1 for s in state["tests"].values() if s == "skip")
    if failing or pending or skipped:
        sys.exit(1)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    args = sys.argv[1:]

    # Parse global flags (before or instead of a command)
    filter_states = None
    verbose = False
    remaining = []
    for a in args:
        if a.startswith("--state="):
            filter_states = set(a.split("=", 1)[1].split(","))
        elif a == "-v":
            verbose = True
        else:
            remaining.append(a)

    if not remaining:
        cmd_status(filter_states=filter_states, verbose=verbose)
        return

    command = remaining[0]

    if command in ("-h", "--help", "help"):
        print(__doc__.strip())
        return
    elif command == "--skill":
        print(AGENT_SKILL.strip())
        return
    elif command == "agent":
        cmd_agent()
        return
    elif command == "init":
        cmd_init(smoke="--smoke" in remaining)
    elif command == "add":
        include_flaky = "--include-flaky" in remaining
        targets = [a for a in remaining[1:] if a != "--include-flaky"]
        if not targets:
            comment("usage: whittle add [--include-flaky] <targets...>")
            sys.exit(1)
        cmd_add(targets, include_flaky)
    elif command == "sync":
        keep_going = "-k" in remaining or "--keep-going" in remaining
        cmd_sync(keep_going=keep_going)
    elif command == "reset":
        cmd_reset(refresh="--reinit" in remaining)
    elif command == "pass":
        test_name = " ".join(remaining[1:])
        if not test_name:
            comment("usage: whittle pass <test_name>")
            sys.exit(1)
        cmd_pass(test_name)
    elif command == "flake":
        test_name = " ".join(remaining[1:])
        if not test_name:
            comment("usage: whittle flake <test_name>")
            sys.exit(1)
        cmd_flake(test_name)
    elif command == "skip":
        test_name = " ".join(remaining[1:])
        if not test_name:
            comment("usage: whittle skip <test_name>")
            sys.exit(1)
        cmd_skip(test_name)
    elif command == "unskip":
        if "--all" in remaining:
            cmd_unskip(all_=True)
        else:
            test_name = " ".join(a for a in remaining[1:] if a != "--all")
            if not test_name:
                comment("usage: whittle unskip <test_name> | --all")
                sys.exit(1)
            cmd_unskip(test_name)
    else:
        comment(f"unknown command: {command}")
        print(__doc__, file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
