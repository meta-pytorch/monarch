def comment(msg):
    """Print a comment line to stdout."""
    print(f"# {msg}")


# ---------------------------------------------------------------------------
# State
# ---------------------------------------------------------------------------

def empty_state():
    return {"targets": [], "flaky_names": [], "tests": {}}


def load_state():
    if not os.path.exists(STATE_FILE):
        comment(f"{STATE_FILE} not found. Run: whittle init")
        sys.exit(1)
    with open(STATE_FILE) as f:
        return json.load(f)


def save_state(state):
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)
        f.write("\n")


# ---------------------------------------------------------------------------
# Platform / buck args
# ---------------------------------------------------------------------------

def get_buck_args():
    machine = platform.machine()
    system = platform.system()
    if system == "Darwin":
        if machine == "arm64":
            return ["@fbcode//mode/mac-arm64"]
        return ["@fbcode//mode/mac"]
    if system == "Linux":
        if machine == "aarch64":
            return ["@fbcode//mode/dev-nosan", "-c=fbcode.arch=aarch64"]
        return ["@fbcode//mode/dev-nosan"]
    comment(f"unknown platform: {system} {machine}")
    sys.exit(1)


# ---------------------------------------------------------------------------
# TestX integration
# ---------------------------------------------------------------------------

def normalize_target(target):
    """Expand short target paths to full fbcode//monarch/ form."""
    if target.startswith("fbcode//"):
        return target
    if target.startswith("//"):
        return "fbcode:" + target
    return "fbcode//monarch/" + target


def query_tests(target):
    """Query testx for all tests in a target (or wildcard like .../...).
    Returns list of dicts with 'name' and 'flaky' keys."""
    is_wildcard = target.endswith("/...")
    search_prefix = normalize_target(target)
    if is_wildcard:
        search_prefix = search_prefix.removesuffix("/...")
    elif ":" not in search_prefix:
        search_prefix = search_prefix.rstrip("/") + ":"
    wildcard_dir = search_prefix.removeprefix("fbcode//") if is_wildcard else None
    tests = []
    try:
        out = subprocess.check_output(
            ["testx", "--as-json", "tests", "search",
             "--starts-with", search_prefix,
             "--limit", "5000"],
            stderr=subprocess.DEVNULL,
            text=True,
        )
        data = json.loads(out)
        seen = set()
        for t in data.get("tests", []):
            name = t["name"].removeprefix("fbcode//")
            if name in seen:
                continue
            parts = name.split(" - ", 1)
            if len(parts) != 2:
                continue
            test_case = parts[1]
            if test_case in ("listing", "main"):
                continue
            target_part = parts[0]
            if target_part.endswith(("-type-checking", "-library")):
                continue
            if wildcard_dir and not (
                target_part.startswith(wildcard_dir + "/")
                or target_part.startswith(wildcard_dir + ":")
            ):
                continue
            seen.add(name)
            tests.append({
                "name": name,
                "flaky": t.get("status") == "FLAKY",
            })
    except (subprocess.CalledProcessError, json.JSONDecodeError, KeyError):
        pass
    return tests


# ---------------------------------------------------------------------------
# Target matching
# ---------------------------------------------------------------------------

def test_matches_target(test_name, target):
    """Check if a test name belongs to a target (or wildcard pattern)."""
    short = target.removeprefix("fbcode//")
    test_target = test_name.split(" - ", 1)[0]
    if short.endswith("/..."):
        prefix = short.removesuffix("/...")
        return test_target.endswith(prefix + "/") or \
               ("/" + prefix + "/") in test_target or \
               ("/" + prefix + ":") in test_target
    elif ":" in short:
        return test_target.endswith(short)
    else:
        return ("/" + short + ":") in test_target or \
               test_target.startswith(short + ":")


# ---------------------------------------------------------------------------
# Event log parsing
# ---------------------------------------------------------------------------

def parse_event_log(path):
    """Parse tpx --event-log-file output. Returns {test_name: "pass"|"fail"}."""
    results = {}
    if not os.path.exists(path):
        return results
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if "test_name" not in obj:
                continue
            name = obj["test_name"]
            status = obj.get("status")
            parts = name.split(" - ", 1)
            if len(parts) == 2:
                test_case = parts[1]
                if test_case in ("listing", "main"):
                    continue
            name = name.removeprefix("fbcode//")
            # tpx status codes: 1=pass (detailed 201), 2=fail (detailed 501)
            if status == 1:
                results[name] = "pass"
            elif status == 2:
                results[name] = "fail"
    return results


# ---------------------------------------------------------------------------
# Test running
# ---------------------------------------------------------------------------

def _parse_event_line(line):
    """Parse a single event log line. Returns (name, status) or None."""
    line = line.strip()
    if not line:
        return None
    try:
        obj = json.loads(line)
    except json.JSONDecodeError:
        return None
    if "test_name" not in obj:
        return None
    name = obj["test_name"]
    status = obj.get("status")
    parts = name.split(" - ", 1)
    if len(parts) == 2 and parts[1] in ("listing", "main"):
        return None
    name = name.removeprefix("fbcode//")
    if status == 1:
        return (name, "pass")
    elif status == 2:
        return (name, "fail")
    return None


def _tail_event_log(path, results, fail_event, stop_event):
    """Tail the event log, populating results dict. Sets fail_event on
    first failure."""
    while not stop_event.is_set() and not os.path.exists(path):
        time.sleep(0.05)
    if stop_event.is_set():
        return
    with open(path) as f:
        while not stop_event.is_set():
            line = f.readline()
            if not line:
                time.sleep(0.05)
                continue
            parsed = _parse_event_line(line)
            if parsed:
                name, status = parsed
                results[name] = status
                if status == "fail":
                    fail_event.set()


def run_tests(buck_args, targets, test_filters, event_log_path,
              fail_fast=False):
    """Run buck2 test, return parsed results even on interrupt.
    If fail_fast, kill buck2 on first test failure."""
    cmd = ["buck2", "test", "--skip-incompatible-targets"] + buck_args + targets
    tpx_args = ["--event-log-file", event_log_path]
    tpx_args += test_filters
    cmd += ["--"] + tpx_args

    print(f"$ {shlex.join(cmd)}")
    sys.stdout.flush()

    interrupted = False
    failed_fast = False
    results = {}
    proc = subprocess.Popen(cmd)

    # Tail the event log in a background thread
    fail_event = threading.Event()
    stop_event = threading.Event()
    tailer = threading.Thread(
        target=_tail_event_log,
        args=(event_log_path, results, fail_event, stop_event),
        daemon=True,
    )
    tailer.start()

    old_handler = signal.getsignal(signal.SIGINT)

    def on_sigint(sig, frame):
        nonlocal interrupted
        interrupted = True
        proc.send_signal(signal.SIGINT)

    signal.signal(signal.SIGINT, on_sigint)
    try:
        if fail_fast:
            # Poll: wait for process exit or first failure
            while proc.poll() is None:
                if fail_event.wait(timeout=0.1):
                    failed_fast = True
                    proc.send_signal(signal.SIGINT)
                    proc.wait()
                    break
        else:
            proc.wait()
    finally:
        signal.signal(signal.SIGINT, old_handler)
        stop_event.set()
        tailer.join(timeout=2)

    # Pick up any remaining lines the tailer didn't get
    for name, status in parse_event_log(event_log_path).items():
        if name not in results:
            results[name] = status

    stopped = interrupted or failed_fast
    reason = "interrupted" if interrupted else "stopped after failure" if failed_fast else None
    return results, stopped, reason


# ---------------------------------------------------------------------------
# Summaries
# ---------------------------------------------------------------------------

def summarize_counts(tests, flaky_names=None):
    """Return a summary string like '10 pass, 2 fail, 3 pending'."""
    counts = {}
    for st in tests.values():
        counts[st] = counts.get(st, 0) + 1
    if flaky_names:
        counts["flaky"] = len(flaky_names)
    parts = []
    for key in ("fail", "pending", "skip", "pass", "removed", "flaky"):
        n = counts.get(key, 0)
        if n:
            parts.append(f"{n} {key}")
    return ", ".join(parts) if parts else "empty"


